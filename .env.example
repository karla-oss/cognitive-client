# Cognitive Overlay — macOS Client Configuration
# Copy to .env and fill in your values

# Signal server API URL
API_BASE_URL=http://localhost:8090

# Your user UUID (auto-generated if empty)
USER_ID=

# Capture settings
CAPTURE_FRAME_RATE=8
CAPTURE_MAX_WIDTH=1280
CAPTURE_MAX_HEIGHT=720

# Overlay settings
OVERLAY_DISPLAY_DURATION=5.0
